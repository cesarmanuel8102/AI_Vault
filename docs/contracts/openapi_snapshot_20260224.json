              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Kind",
            "default": "fact"
          },
          "source": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source"
          }
        },
        "type": "object",
        "required": [
          "text"
        ],
        "title": "MemoryFactIn"
      },
      "MemoryQueryIn": {
        "properties": {
          "query": {
            "type": "string",
            "minLength": 1,
            "title": "Query"
          },
          "limit": {
            "type": "integer",
            "maximum": 50.0,
            "minimum": 1.0,
            "title": "Limit",
            "default": 10
          }
        },
        "type": "object",
        "required": [
          "query"
        ],
        "title": "MemoryQueryIn"
      },
      "MissionCreate": {
        "properties": {
          "objective": {
            "type": "string",
            "minLength": 3,
            "title": "Objective"
          },
          "constraints": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Constraints"
          }
        },
        "type": "object",
        "required": [
          "objective"
        ],
        "title": "MissionCreate"
      },
      "PlanCreate": {
        "properties": {
          "max_steps": {
            "type": "integer",
            "maximum": 50.0,
            "minimum": 1.0,
            "title": "Max Steps",
            "default": 8
          },
          "style": {
            "type": "string",
            "title": "Style",
            "default": "pragmatic"
          }
        },
        "type": "object",
        "title": "PlanCreate"
      },
      "PolicyUpdate": {
        "properties": {
          "allowed_read_roots": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Allowed Read Roots"
          },
          "allowed_write_roots": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Allowed Write Roots"
          },
          "deny_contains": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Deny Contains"
          },
          "max_write_bytes_per_call": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Write Bytes Per Call"
          }
        },
        "type": "object",
        "title": "PolicyUpdate"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
