# AI_VAULT runtime credentials
# Copy to .env locally and replace placeholders with your real values.
# Never commit the real .env file.

OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Optional runtime overrides
BRAIN_PORT=8090
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
POCKETOPTION_BRIDGE_URL=http://127.0.0.1:8765
