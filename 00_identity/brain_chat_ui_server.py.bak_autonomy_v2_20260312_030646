        try:
            br = await client.get(f"{BRAIN_API}/v1/agent/healthz")
            data["brain_health"] = br.json()
        except Exception as e:
            data["ok"] = False
            data["brain_health"] = {"ok": False, "error": repr(e)}

    return JSONResponse(data)

@app.post("/api/chat")
async def api_chat(body: ChatBody):
    message = str(body.message or "").strip()
    room_id = str(body.room_id or ("ui_" + uuid.uuid4().hex[:10]))
    auto_apply = bool(body.auto_apply)

    if not message:
        return JSONResponse({"ok": False, "kind": "error", "room_id": room_id, "reply": "Mensaje vacío."}, status_code=400)

    advisor_payload = {
        "room_id": room_id,
        "publish": False,
        "mode": "planner",
        "prompt": message
    }

    async with httpx.AsyncClient(timeout=45.0) as client:
        try:
            advisor_resp = await client.post(
                f"{ADVISOR_API}/v1/advisor/next",
                json=advisor_payload,
                headers={"Content-Type": "application/json; charset=utf-8"}
            )
            advisor_obj = advisor_resp.json()
        except Exception as e:
            return JSONResponse({
                "ok": False,
                "kind": "error",
                "room_id": room_id,
                "reply": f"Fallo llamando advisor: {repr(e)}"
            }, status_code=500)

        if str(advisor_obj.get("status") or "") == "clarification_required":
            return {
                "ok": True,
                "kind": "clarification",
                "room_id": room_id,
                "reply": str(advisor_obj.get("clarification_question") or "Necesito una aclaración."),
                "advisor": advisor_obj
            }

        if _detect_placeholder(advisor_obj):
            return JSONResponse({
                "ok": False,
                "kind": "error",
                "room_id": room_id,
                "reply": "El advisor no devolvió un plan real; se bloqueó la ejecución para evitar falsos positivos.",
                "advisor": advisor_obj
            }, status_code=409)

        plan = _extract_plan(advisor_obj)
        if not isinstance(plan, dict):
            return JSONResponse({
                "ok": False,
                "kind": "error",
                "room_id": room_id,
                "reply": "El advisor no devolvió un plan estructurado.",
                "advisor": advisor_obj
            }, status_code=409)

        steps = list(plan.get("steps") or [])
        if not steps:
            return JSONResponse({
                "ok": False,
                "kind": "error",
                "room_id": room_id,
                "reply": "El advisor devolvió un plan sin pasos.",
                "advisor": advisor_obj
            }, status_code=409)

        try:
            publish_resp = await client.post(
                f"{BRAIN_API}/v1/agent/plan",
                headers={
                    "x-room-id": room_id,
                    "Content-Type": "application/json; charset=utf-8"
                },
                content=json.dumps(plan, ensure_ascii=False)
            )
            publish_obj = publish_resp.json()
        except Exception as e:
            return JSONResponse({
                "ok": False,
                "kind": "error",
                "room_id": room_id,
                "reply": f"Falló /v1/agent/plan: {repr(e)}",
                "advisor": advisor_obj
            }, status_code=500)

        try:
            run1_resp = await client.post(
                f"{BRAIN_API}/v1/agent/run_once",
                headers={
                    "x-room-id": room_id,
                    "Content-Type": "application/json; charset=utf-8"
                },
                content=json.dumps({"room_id": room_id, "max_steps": 1}, ensure_ascii=False)
            )
            run1_obj = run1_resp.json()
        except Exception as e:
            return JSONResponse({
                "ok": False,
                "kind": "error",
                "room_id": room_id,
                "reply": f"Falló /v1/agent/run_once: {repr(e)}",
                "advisor": advisor_obj,
                "brain": {"plan_publish": publish_obj}
            }, status_code=500)

        apply_obj = None
        run2_obj = None

        plan_after_run = _room_plan(room_id)
        approve_token = None
        if isinstance(plan_after_run, dict):
            for s in list(plan_after_run.get("steps") or []):
                tok = s.get("required_approve")
                if tok:
                    approve_token = tok
                    break

        if auto_apply and approve_token:
            try:
                apply_resp = await client.post(
                    f"{BRAIN_API}/v1/agent/apply",
                    headers={
                        "x-room-id": room_id,
                        "Content-Type": "application/json; charset=utf-8"
                    },
                    content=json.dumps({"room_id": room_id, "approve_token": approve_token}, ensure_ascii=False)
                )
                apply_obj = apply_resp.json()

                run2_resp = await client.post(
                    f"{BRAIN_API}/v1/agent/run_once",
                    headers={
                        "x-room-id": room_id,
                        "Content-Type": "application/json; charset=utf-8"
                    },
                    content=json.dumps({"room_id": room_id, "max_steps": 1}, ensure_ascii=False)
                )
                run2_obj = run2_resp.json()
            except Exception as e:
                return JSONResponse({
                    "ok": False,
                    "kind": "error",
                    "room_id": room_id,
                    "reply": f"Falló apply/run2: {repr(e)}",
                    "advisor": advisor_obj,
                    "brain": {
                        "plan_publish": publish_obj,
                        "run_once_1": run1_obj
                    }
                }, status_code=500)

        reply = _human_reply_from_plan(room_id, steps)

        return {
            "ok": True,
            "kind": "result",
            "room_id": room_id,
            "reply": reply,
            "advisor": advisor_obj,
            "brain": {
                "plan_publish": {"ok": True, "data": publish_obj},
                "run_once_1": {"ok": True, "data": run1_obj},
                "apply": apply_obj,
                "run_once_2": run2_obj
            },
            "ts_utc": _now_utc()
        }