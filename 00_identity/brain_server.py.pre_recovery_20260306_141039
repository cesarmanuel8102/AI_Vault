    # HARDENING_EPISODE_FORCE_ENRICH_P3_1_V1
    # Ensure proposals[] + tool_calls[] always materialize; derive from plan.json + proposals dir
    # ============================
    try:
        ep.setdefault('proposals', [])
        ep.setdefault('tool_calls', [])
