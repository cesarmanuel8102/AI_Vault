            stp = _first(_plan, lambda s: s.get("status") == "proposed" and s.get("proposal_id") and s.get("required_approve"))
            if isinstance(stp, dict):
                ep["proposals"].append({"ts": nowz(), "action":"propose", "step_id": stp.get("id") or stp.get("step_id"),
                                       "proposal_id": stp.get("proposal_id"), "approve_token": stp.get("required_approve")})
    
        if isinstance(_plan, dict) and ph == "apply":
            std = _first(_plan, lambda s: s.get("status") == "done" and s.get("tool_name"))
            if isinstance(std, dict):
                ep["tool_calls"].append({"ts_start": nowz(), "ts_end": nowz(), "tool_name": std.get("tool_name"),
