    room_id: Query o header x-room-id (default).
    """
    import os, json

    rid = (room_id or "").strip() or None
    if not rid:
        try:
            rid = (request.headers.get("x-room-id") or request.headers.get("X-Room-Id") or "default").strip() or "default"
        except Exception:
            rid = "default"
    rid = rid or "default"

