def episode_wrap(phase: str):
    def deco(fn):
        def _wrapped(*args, **kwargs):
            __ep = _episode_begin(locals(), phase=phase)
            try:
                ret = fn(*args, **kwargs)
                # P3_1_EPISODE_WRAP_MUTATE_EP_V6
                try:
                    # ensure arrays on the canonical episode object
                    __ep.setdefault('proposals', [])
                    __ep.setdefault('tool_calls', [])
                    __ep.setdefault('plan_path', __ep.get('plan_path'))
                    __ep.setdefault('plan_sha256', __ep.get('plan_sha256'))
                    __ep.setdefault('plan_mtime', __ep.get('plan_mtime'))
                    _req = kwargs.get('req') if isinstance(kwargs, dict) else None
                    if not isinstance(_req, dict):
                        _req = None
                    _ret = ret
                    _blocked = None
                    if isinstance(_ret, dict):
                        _blocked = _ret.get('blocked') or (_ret.get('result', {}).get('blocked') if isinstance(_ret.get('result'), dict) else None)
                    # propose
                    if isinstance(_blocked, dict) and _blocked.get('proposal_id') and _blocked.get('required_approve'):
                        __ep['proposals'].append({
                            'ts': _ep_nowz(),
                            'action': 'propose',
                            'step_id': _blocked.get('step_id'),
                            'proposal_id': _blocked.get('proposal_id'),
                            'approve_token': _blocked.get('required_approve'),
                        })
                    # apply
                    _tok = None
                    if isinstance(_req, dict):
                        _tok = _req.get('approve_token') or _req.get('required_approve')
                    if isinstance(_tok, str) and _tok.startswith('APPLY_'):
                        _pid = _tok.replace('APPLY_', '', 1)
                        _sid = None
                        if isinstance(_ret, dict):
                            _sid = _ret.get('step_id') or (_ret.get('result', {}).get('step_id') if isinstance(_ret.get('result'), dict) else None)
                        __ep['proposals'].append({
                            'ts': _ep_nowz(),
                            'action': 'apply',
                            'step_id': _sid,
                            'proposal_id': _pid,
                            'approve_token': _tok,
                        })
                    # tool_calls from apply response
                    if isinstance(_ret, dict):
                        pl = _ret.get('plan')
                        if isinstance(pl, dict):
                            steps = pl.get('steps')
                            if isinstance(steps, list) and steps:
                                st = steps[0]
                                if isinstance(st, dict) and st.get('tool_name'):
                                    __ep['tool_calls'].append({
                                        'ts_start': _ep_nowz(),
                                        'ts_end': _ep_nowz(),
                                        'tool_name': st.get('tool_name'),
                                        'tool_args': st.get('tool_args') or {},
                                        'result': st.get('result') or _ret.get('result') or {},
                                        'ok': True,
                                    })
                except Exception:
                    pass
                # P3_1_EPISODE_WRAP_POSTHOOK_V5
                try:
                    _rid = None
                    try:
                        _rid = _ep_infer_room_id(args, kwargs)
                    except Exception:
                        _rid = None
                    _phase = phase
                    _req = kwargs.get('req')
                    if not isinstance(_req, dict):
                        _req = None
                    _ret = ret
                    if _rid:
                        _run_id = 'run_' + uuid.uuid4().hex[:12]
                        _epi = _p3_new_run(_rid, _phase or 'unknown', _run_id)
                        _blocked = None
                        if isinstance(_ret, dict):
                            _blocked = _ret.get('blocked') or (_ret.get('result', {}).get('blocked') if isinstance(_ret.get('result'), dict) else None)
                        if isinstance(_blocked, dict) and _blocked.get('proposal_id') and _blocked.get('required_approve'):
                            _p3_add_proposal(_epi, 'propose', _blocked.get('step_id'), _blocked.get('proposal_id'), _blocked.get('required_approve'))
                        _tok = None
                        if isinstance(_req, dict):
                            _tok = _req.get('approve_token') or _req.get('required_approve')
                        if isinstance(_tok, str) and _tok.startswith('APPLY_'):
                            _pid = _tok.replace('APPLY_', '', 1)
                            _sid = None
                            if isinstance(_ret, dict):
                                _sid = _ret.get('step_id') or (_ret.get('result', {}).get('step_id') if isinstance(_ret.get('result'), dict) else None)
                            _p3_add_proposal(_epi, 'apply', _sid, _pid, _tok)
                        if isinstance(_ret, dict):
                            pl = _ret.get('plan')
                            if isinstance(pl, dict):
                                steps = pl.get('steps')
                                if isinstance(steps, list) and steps:
                                    st = steps[0]
                                    if isinstance(st, dict):
                                        _tname = st.get('tool_name')
                                        _targs = st.get('tool_args')
                                        _tres  = st.get('result') or _ret.get('result')
                                        if _tname:
                                            _p3_add_tool_call(_epi, _tname, _targs or {}, _tres or {}, True)
                        _epi['result'] = {'ok': True}
                        _p3_write_episode_run(_epi)
                except Exception:
                    pass
            except Exception as e:
                __ep.setdefault("errors", []).append("exception: " + repr(e))
                _episode_end(__ep, {"ok": False, "error": "exception", "detail": repr(e)})
                raise
            _episode_end(__ep, ret)
            return ret
        return _wrapped
    return deco

# HARDENING_EPISODE_P3_1_BOOTSTRAP_V2_CANON (ensure episode_wrap exists at import-time; room_id inferred from args/kwargs)
def _ep_nowz():
    from datetime import datetime, timezone
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

def _ep_infer_room_id(args, kwargs):
    # 1) direct kwargs
    for k in ("room_id","rid"):
        v = kwargs.get(k)
        if isinstance(v, str) and v.strip():
            return v.strip()

    # 2) common kwargs objects/dicts
    for k in ("req","body","payload"):
        v = kwargs.get(k)
        if v is None:
            continue
        rid = getattr(v, "room_id", None)
        if isinstance(rid, str) and rid.strip():
            return rid.strip()
        if isinstance(v, dict):
            rid = v.get("room_id") or v.get("rid")
            if isinstance(rid, str) and rid.strip():
                return rid.strip()

    # 3) positional args objects/dicts
    for v in (args or ()):
        rid = getattr(v, "room_id", None)
        if isinstance(rid, str) and rid.strip():
            return rid.strip()
        if isinstance(v, dict):
            rid = v.get("room_id") or v.get("rid")
            if isinstance(rid, str) and rid.strip():
                return rid.strip()

    return "default"

