def _snapshot_kv_load(room_id: str) -> dict:
    p = Path(_runtime_snapshot_path(room_id))
    if not p.exists():
        return {}
    try:
        obj = json.loads(p.read_text(encoding="utf-8", errors="ignore")) or {}
    except Exception:
        return {}
    # Legacy single-record: {room_id, path, value}
    if isinstance(obj, dict) and ("path" in obj) and ("value" in obj) and (len(obj.keys()) <= 6):
        try:
            legacy_path = str(obj.get("path") or "")
            legacy_value = obj.get("value", None)
            if legacy_path:
                return {legacy_path: legacy_value}
        except Exception:
            return {}
    if isinstance(obj, dict):
        return obj
    return {}

def _snapshot_kv_save(room_id: str, kv: dict) -> str:
    p = Path(_runtime_snapshot_path(room_id))
    p.parent.mkdir(parents=True, exist_ok=True)
    if kv is None or not isinstance(kv, dict):
        kv = {}
    p.write_text(json.dumps(kv, ensure_ascii=False, indent=2), encoding="utf-8")
    return str(p)
