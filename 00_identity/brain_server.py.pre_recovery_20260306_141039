@app.post("/v1/agent/loop")
def agent_loop_multi_ssot(request: Request, req: dict = Body(...)):
    """
    Loop (multi) SSOT:
      input: { room_id?, max_iters?, max_steps_per_iter? }
      output: { ok, room_id, iterations[], stopped_reason, blocked?, evaluation? }
    """
    import os, json

    # room_id: body -> header -> default
    room_id = None
    try:
        if isinstance(req, dict):
            room_id = req.get("room_id")
    except Exception:
        room_id = None
    if not room_id:
        room_id = (request.headers.get("x-room-id") or "").strip() or "default"

    max_iters = 10
    try:
        if isinstance(req, dict) and req.get("max_iters") is not None:
            max_iters = int(req.get("max_iters"))
    except Exception:
        max_iters = 10
    if max_iters < 1:
        max_iters = 1
    if max_iters > 50:
        max_iters = 50

    max_steps_per_iter = 1
    try:
        if isinstance(req, dict) and req.get("max_steps_per_iter") is not None:
            max_steps_per_iter = int(req.get("max_steps_per_iter"))
    except Exception:
        max_steps_per_iter = 1
    if max_steps_per_iter < 1:
        max_steps_per_iter = 1
    if max_steps_per_iter > 10:
        max_steps_per_iter = 10

    iterations = []
    stopped_reason = "max_iters"
    final_blocked = None
    final_eval = None

    for k in range(max_iters):
        one = agent_loop_once_ssot(request, {"room_id": room_id, "max_steps": max_steps_per_iter})
        # Normaliza estructura
        blocked = None
        evaluation = None
        try:
            if isinstance(one, dict):
                blocked = one.get("blocked")
                evaluation = one.get("evaluation")
        except Exception:
            blocked = None
            evaluation = None

        iterations.append({
            "i": k + 1,
            "ok": bool(one.get("ok", True)) if isinstance(one, dict) else True,
            "blocked": blocked,
            "evaluation": evaluation,
            "impl": (one.get("impl") if isinstance(one, dict) else None),
        })

        # stop if blocked needs approval
        if isinstance(blocked, dict) and blocked.get("required_approve"):
            stopped_reason = "needs_approval"
            final_blocked = blocked
            final_eval = evaluation
            break

        # stop if plan is complete (SSOT plan.json)
        try:
            plan_path = os.path.join(r"C:\AI_VAULT\tmp_agent\state\rooms", str(room_id), "plan.json")
            if os.path.exists(plan_path):
                with open(plan_path, "r", encoding="utf-8") as f:
                    plan = json.load(f)
                if isinstance(plan, dict) and str(plan.get("status") or "").lower() == "complete":
                    stopped_reason = "complete"
                    final_blocked = None
                    final_eval = evaluation
                    break
        except Exception:
            pass

        # if loop_once returned ok but nothing to do (best-effort)
        try:
            ro = (one.get("run_once") if isinstance(one, dict) else None)
            if isinstance(ro, dict):
                act = str(ro.get("action") or "")
                if act.startswith("noop"):
                    stopped_reason = act
                    final_blocked = None
                    final_eval = evaluation
                    break
        except Exception:
            pass

        final_blocked = blocked
        final_eval = evaluation

    return {
        "ok": True,
        "room_id": room_id,
        "iterations": iterations,
        "stopped_reason": stopped_reason,
        "blocked": final_blocked,
        "evaluation": final_eval,
        "impl": "HARDENING_P3_3_LOOP_MULTI_SSOT_V1"
    }

