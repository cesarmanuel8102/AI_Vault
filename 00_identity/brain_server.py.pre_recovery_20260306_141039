import json as _json_p3
import hashlib as _hashlib_p3

def _p3_utc_iso():
    return datetime.now(timezone.utc).isoformat().replace("+00:00","Z")

def _p3_room_dir(room_id: str) -> str:
    try:
        return _room_path(room_id)  # if your code has it
    except Exception:
        return os.path.join(r"C:\AI_VAULT\tmp_agent\state\rooms", str(room_id))

def _p3_safe_mkdir(d: str):
    try:
        os.makedirs(d, exist_ok=True)
    except Exception:
        pass

def _p3_plan_refs(room_id: str) -> dict:
    rd=_p3_room_dir(room_id)
    plan_path=os.path.join(rd,"plan.json")
    out={"plan_path": plan_path if os.path.exists(plan_path) else None,
         "plan_sha256": None,
         "plan_mtime": None}
    try:
        if os.path.exists(plan_path):
            out["plan_mtime"]=datetime.fromtimestamp(os.path.getmtime(plan_path),timezone.utc).isoformat().replace("+00:00","Z")
            h=_hashlib_p3.sha256()
            with open(plan_path,"rb") as f:
                for b in iter(lambda: f.read(1024*1024), b""):
                    h.update(b)
            out["plan_sha256"]=h.hexdigest()
    except Exception:
        pass
    return out

def _p3_episode_paths(room_id: str) -> dict:
    rd=_p3_room_dir(room_id)
    eps=os.path.join(rd,"episodes")
    _p3_safe_mkdir(eps)
    return {"room_dir": rd, "episodes_dir": eps}

def _p3_write_json(path: str, obj: dict):
    tmp=path+".tmp"
    with open(tmp,"w",encoding="utf-8") as f:
        _json_p3.dump(obj,f,ensure_ascii=False,indent=2)
    os.replace(tmp,path)

def _p3_new_run(room_id: str, phase: str, run_id: str) -> dict:
    refs=_p3_plan_refs(room_id)
    return {
        "ts_start": _p3_utc_iso(),
        "ts_end": None,
        "room_id": room_id,
        "run_id": run_id,
        "phase": phase,
        "plan_path": refs.get("plan_path"),
        "plan_sha256": refs.get("plan_sha256"),
        "plan_mtime": refs.get("plan_mtime"),
        "tool_calls": [],
        "proposals": [],
        "result": None,
        "errors": [],
    }

def _p3_add_tool_call(run_obj: dict, tool_name: str, tool_args: dict, result: dict, ok: bool, ts_start: str=None, ts_end: str=None):
    run_obj["tool_calls"].append({
        "ts_start": ts_start or _p3_utc_iso(),
        "ts_end": ts_end or _p3_utc_iso(),
        "tool_name": tool_name,
        "tool_args": tool_args or {},
        "result": result or {},
        "ok": bool(ok),
    })

def _p3_add_proposal(run_obj: dict, action: str, step_id: str, proposal_id: str, approve_token: str):
    run_obj["proposals"].append({
        "ts": _p3_utc_iso(),
        "action": action,
        "step_id": step_id,
        "proposal_id": proposal_id,
        "approve_token": approve_token,
    })

def _p3_write_episode_run(run_obj: dict):
    room_id=run_obj.get("room_id")
    run_id=run_obj.get("run_id")
    if not room_id or not run_id:
        return
    ep=_p3_episode_paths(room_id)
