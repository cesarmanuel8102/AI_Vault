def _json_bytes(obj):
    return json.dumps(obj).encode("utf-8")

def _post_json(url, obj, headers=None, timeout=90):
    headers = headers or {}
    req = urllib.request.Request(
        url,
        data=_json_bytes(obj),
        headers={"Content-Type": "application/json; charset=utf-8", **headers},
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        raw = resp.read().decode("utf-8", errors="replace")
        return json.loads(raw) if raw else {}

def _get_json(url, headers=None, timeout=30):
    headers = headers or {}
    req = urllib.request.Request(url, headers=headers, method="GET")
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        raw = resp.read().decode("utf-8", errors="replace")
        return json.loads(raw) if raw else {}

def _safe_post(url, obj, headers=None, timeout=90):
    try:
        return {"ok": True, "data": _post_json(url, obj, headers=headers, timeout=timeout)}
    except Exception as e:
        return {"ok": False, "error": repr(e)}

def _safe_get(url, headers=None, timeout=30):
    try:
        return {"ok": True, "data": _get_json(url, headers=headers, timeout=timeout)}
    except Exception as e:
        return {"ok": False, "error": repr(e)}

def _extract_path(message: str) -> str:
    msg = str(message or "")
    candidates = []
    parts = msg.replace('"', ' " ').replace("'", " ' ").split()
    for p in parts:
        if p.startswith("C:\\") or p.startswith("D:\\"):
            candidates.append(p.strip('"\''))

    if candidates:
        return candidates[0]

    lower = msg.lower()
    if "tmp_agent\\state" in lower:
        return r"C:\AI_VAULT\tmp_agent\state"
    if "ai_vault" in lower:
        return r"C:\AI_VAULT"
    return ""

def _local_fallback(message: str, room_id: str):
    msg = str(message or "").strip()
    low = msg.lower()
    path = _extract_path(msg) or r"C:\AI_VAULT\tmp_agent\state"

    explicit_list = any(x in low for x in ["lista", "listar", "directorio", "carpeta", "list directory", "list dir", "show files", "muestra archivos"])
    explicit_read = any(x in low for x in ["lee", "leer", "read file", "abre archivo", "show file", "muestra archivo"])
    ambiguous = any(x in low for x in ["avanza", "adelante", "continúa", "continua", "hazlo", "sigue", "resuelve"]) and not explicit_list and not explicit_read

    if explicit_list:
        return {
            "mode": "plan",
            "plan": {
                "room_id": room_id,
                "status": "active",
                "steps": [
                    {
                        "id": "S1",
                        "status": "todo",
                        "tool_name": "list_dir",
                        "tool_args": {"path": path},
                        "why": "list_dir explicit fallback"
                    }
                ]
            }
        }

    if explicit_read:
        return {
            "mode": "plan",
            "plan": {
                "room_id": room_id,
                "status": "active",
                "steps": [
                    {
                        "id": "S1",
                        "status": "todo",
                        "tool_name": "read_file",
                        "tool_args": {"path": path},
                        "why": "read_file explicit fallback"
                    }
                ]
            }
        }

    if ambiguous:
        return {
            "mode": "clarification",
            "question": "¿Qué acción exacta quieres que ejecute y sobre qué ruta o recurso concreto?"
        }

    return {
        "mode": "noop",
        "question": "Necesito más precisión para ejecutar algo útil. Indícame acción y ruta concreta."
    }

def _extract_plan_from_advisor(obj, room_id: str):
    if not isinstance(obj, dict):
        return {"room_id": room_id, "status": "complete", "steps": []}

    plan = obj.get("plan")
    if isinstance(plan, dict):
        plan["room_id"] = room_id
        if not isinstance(plan.get("steps"), list):
            plan["steps"] = []
        if not plan.get("status"):
            plan["status"] = "complete" if len(plan["steps"]) == 0 else "active"
        return plan

    steps = obj.get("steps")
    if isinstance(steps, list):
        return {"room_id": room_id, "status": "active" if steps else "complete", "steps": steps}

    return {"room_id": room_id, "status": "complete", "steps": []}

def _approve_token_from_plan(plan):
    if not isinstance(plan, dict):
        return None
    steps = plan.get("steps") or []
    if isinstance(steps, list):
        for s in steps:
            if isinstance(s, dict):
                tok = s.get("required_approve")
                if tok:
                    return tok
    return None

class ChatIn(BaseModel):
    message: str
    room_id: str = ""
    auto_apply: bool = True

@app.get("/healthz")
def healthz():
    advisor = _safe_get(f"{ADVISOR_API}/healthz")
    brain = _safe_get(f"{BRAIN_API}/v1/agent/healthz")
    return {
        "ok": advisor.get("ok", False) and brain.get("ok", False),
        "advisor_api": ADVISOR_API,
        "brain_api": BRAIN_API,
        "advisor_health": advisor.get("data"),
        "brain_health": brain.get("data"),
    }

@app.get("/api/status")
def api_status(room_id: str):
    room_id = room_id or "default"
    st = _safe_get(f"{BRAIN_API}/v1/agent/status?room_id={urllib.parse.quote(room_id)}")
    return st.get("data") if st.get("ok") else {"ok": False, "error": st.get("error"), "room_id": room_id}

@app.post("/api/chat")
def api_chat(inp: ChatIn):
    room_id = (inp.room_id or "").strip() or f"web_room_{int(time.time())}"
    msg = (inp.message or "").strip()

    advisor_payload = {
        "room_id": room_id,
        "publish": False,
        "mode": "planner",
        "prompt": msg
    }

    advisor_raw = _safe_post(f"{ADVISOR_API}/v1/advisor/next", advisor_payload)

    if advisor_raw.get("ok"):
        advisor = advisor_raw["data"]
    else:
        advisor = {"status": "error", "error": advisor_raw.get("error")}

    if isinstance(advisor, dict) and advisor.get("status") == "clarification_required":
        return {
            "ok": True,
            "kind": "clarification",
            "room_id": room_id,
            "reply": advisor.get("clarification_question") or "Necesito una aclaración puntual.",
            "advisor": advisor,
            "brain": None
        }

    plan = _extract_plan_from_advisor(advisor, room_id)

    if not isinstance(plan.get("steps"), list) or len(plan.get("steps")) == 0:
        fb = _local_fallback(msg, room_id)
        if fb["mode"] == "clarification":
            return {
                "ok": True,
                "kind": "clarification",
                "room_id": room_id,
                "reply": fb["question"],
                "advisor": advisor,
                "brain": None
            }
        if fb["mode"] == "plan":
            plan = fb["plan"]
        else:
            return {
                "ok": True,
                "kind": "noop",
                "room_id": room_id,
                "reply": fb["question"],
                "advisor": advisor,
                "brain": None
            }

    plan_pub = _safe_post(
        f"{BRAIN_API}/v1/agent/plan",
        plan,
        headers={"x-room-id": room_id}
    )
    run1 = _safe_post(
        f"{BRAIN_API}/v1/agent/run_once",
        {"room_id": room_id, "max_steps": 1},
        headers={"x-room-id": room_id}
    )

    apply_resp = None
    run2 = None

    approve_token = None
    if run1.get("ok") and isinstance(run1.get("data"), dict):
        blocked = run1["data"].get("blocked")
        if isinstance(blocked, dict):
            approve_token = blocked.get("required_approve")

    if not approve_token and plan_pub.get("ok") and isinstance(plan_pub.get("data"), dict):
        approve_token = _approve_token_from_plan(plan_pub["data"].get("plan"))

    if inp.auto_apply and approve_token:
        apply_resp = _safe_post(
            f"{BRAIN_API}/v1/agent/apply",
            {"room_id": room_id, "approve_token": approve_token},
            headers={"x-room-id": room_id}
        )
        run2 = _safe_post(
            f"{BRAIN_API}/v1/agent/run_once",
            {"room_id": room_id, "max_steps": 1},
            headers={"x-room-id": room_id}
        )

    st = _safe_get(f"{BRAIN_API}/v1/agent/status?room_id={urllib.parse.quote(room_id)}")
    status_data = st.get("data") if st.get("ok") else {"ok": False, "error": st.get("error")}

    steps_n = len(plan.get("steps") or [])
    reply = f"Procesé la petición en room {room_id}. Pasos del plan: {steps_n}."

    if approve_token and apply_resp and apply_resp.get("ok"):
        reply += " Hubo approval y fue autoaplicado."
    elif approve_token:
        reply += " Hubo approval pendiente."

    return {
        "ok": True,
        "kind": "result",
        "room_id": room_id,
        "reply": reply,
        "advisor": advisor,
        "brain": {
            "plan_publish": plan_pub,
            "run_once_1": run1,
            "apply": apply_resp,
            "run_once_2": run2,
            "status": status_data
        }
    }

