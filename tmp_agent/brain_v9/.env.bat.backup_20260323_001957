@echo off
:: ── Rutas ────────────────────────────────────────────────────────────────────
set BRAIN_BASE_PATH=C:\AI_VAULT
set BRAIN_HOST=127.0.0.1
set BRAIN_PORT=8090

:: ── Modelo: deepseek-r1:14b (9GB, velocidad + calidad optimizadas) ────────────
set OLLAMA_URL=http://localhost:11434/api/generate
set OLLAMA_MODEL=deepseek-r1:14b

:: Alternativas (descomentar para cambiar):
:: set OLLAMA_MODEL=deepseek-r1:32b       ← 19GB, maxima calidad (mas lento)
:: set OLLAMA_MODEL=qwen2.5-coder:14b   ← 9GB, especializado en codigo

:: ── Timeouts ─────────────────────────────────────────────────────────────────
set LLM_TIMEOUT=120
set LLM_RETRY_DELAY=2.0
set LLM_MAX_RETRIES=2

:: ── Tokens ───────────────────────────────────────────────────────────────────
set LLM_MAX_TOKENS=8192
set LLM_TEMPERATURE=0.7

:: ── Autonomía ─────────────────────────────────────────────────────────────────
set AUTO_DEBUG=true
set AUTO_OPT=true
set AUTO_MONITOR=true
set DEBUG_INTERVAL=300
set OPT_INTERVAL=600
set MONITOR_INTERVAL=300
