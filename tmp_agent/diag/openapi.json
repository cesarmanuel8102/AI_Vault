  "components": {
    "schemas": {
      "AgentEvalRequest": {
        "properties": {
          "observation": {
            "additionalProperties": true,
            "type": "object",
            "title": "Observation"
          },
          "room_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Room Id"
          }
        },
        "type": "object",
        "title": "AgentEvalRequest"
      },
      "AgentEvalResponse": {
        "properties": {
          "ok": {
            "type": "boolean",
            "title": "Ok"
          },
          "plan": {
            "additionalProperties": true,
            "type": "object",
            "title": "Plan"
          },
          "verdict": {
            "additionalProperties": true,
            "type": "object",
            "title": "Verdict"
          }
        },
        "type": "object",
        "required": [
          "ok",
          "plan",
          "verdict"
        ],
        "title": "AgentEvalResponse"
      },
      "AgentPlanRequest": {
        "properties": {
          "goal": {
            "type": "string",
            "minLength": 1,
            "title": "Goal"
          },
          "room_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Room Id"
          },
          "context": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "goal"
        ],
        "title": "AgentPlanRequest"
      },
      "AgentPlanResponse": {
        "properties": {
          "ok": {
            "type": "boolean",
            "title": "Ok"
          },
          "mission": {
            "additionalProperties": true,
            "type": "object",
            "title": "Mission"
          },
          "plan": {
            "additionalProperties": true,
            "type": "object",
            "title": "Plan"
          }
        },
        "type": "object",
        "required": [
          "ok",
          "mission",
          "plan"
        ],
        "title": "AgentPlanResponse"
      },
      "ExecuteStepReq": {
        "properties": {
          "step_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Step Id"
          }
        },
        "type": "object",
        "title": "ExecuteStepReq"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "MemoryCompactIn": {
        "properties": {
          "promote": {
            "type": "boolean",
            "title": "Promote",
            "default": true
          },
          "keep_backup": {
            "type": "boolean",
            "title": "Keep Backup",
            "default": true
          }
        },
        "type": "object",
