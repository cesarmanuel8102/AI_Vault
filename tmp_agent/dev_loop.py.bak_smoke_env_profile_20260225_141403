    def smoke_mode(self, contract_path: str, profile: Optional[str] = None) -> Dict[str, Any]:
        """
        Runs smoke_runner.py using repo imports (PYTHONPATH=REPO_ROOT) and the given contract path.
        """
        self.logger.emit("run_start", {"mode": "smoke", "contract_path": contract_path})

        cpath = Path(contract_path).resolve()
        if not cpath.exists():
            out = {"ok": False, "error": "CONTRACT_NOT_FOUND", "contract_path": str(cpath)}
            self.logger.emit("smoke_result", out)
            self.logger.emit("run_end", {"mode": "smoke", "ok": False})
            return out

        runner = (SANDBOX_ROOT / "smoke_runner.py").resolve()
        if not runner.exists():
            out = {"ok": False, "error": "SMOKE_RUNNER_NOT_FOUND", "runner": str(runner)}
            self.logger.emit("smoke_result", out)
            self.logger.emit("run_end", {"mode": "smoke", "ok": False})
            return out

        env = {
            "PYTHONPATH": str(REPO_ROOT),
            "BRAINLAB_CONTRACT": str(cpath),
        }

        try:
            res = self.exec.run_cmd(["python", str(runner)], cwd=str(SANDBOX_ROOT), env=env)

            parsed = None
            stdout = ""
            if isinstance(getattr(res, "data", None), dict):
                stdout = (res.data.get("stdout") or "").strip()
                if stdout:
                    try:
                        parsed = json.loads(stdout)
                    except Exception:
                        parsed = None

            out = {
                "ok": bool(getattr(res, "ok", False)),
                "detail": getattr(res, "detail", ""),
                "returncode": (res.data.get("returncode") if isinstance(getattr(res, "data", None), dict) else None),
                "stdout": (res.data.get("stdout") if isinstance(getattr(res, "data", None), dict) else ""),
                "stderr": (res.data.get("stderr") if isinstance(getattr(res, "data", None), dict) else ""),
                "cmd": (res.data.get("cmd") if isinstance(getattr(res, "data", None), dict) else None),
                "parsed": parsed,
                "contract_path": str(cpath),
                "runner": str(runner),
                "repo_root": str(REPO_ROOT),
            }
        except Exception as e:
            try:
                import traceback
                out = {
                    "ok": False,
                    "error_type": e.__class__.__name__,
                    "message": str(e),
                    "traceback": traceback.format_exc()[-4000:],
                }
            except Exception:
                out = {"ok": False, "error_type": "Exception", "message": str(e)}

        self.logger.emit("smoke_result", out)

        try:
            self.state["last_smoke"] = {
                "ts": utc_now_iso(),
                "ok": out.get("ok"),
                "contract_path": str(cpath),
                "run_id": self.run_id
            }
            save_state(self.state)
        except Exception:
            pass

        self.logger.emit("run_end", {"mode": "smoke", "ok": bool(out.get("ok", False))})
        return out
