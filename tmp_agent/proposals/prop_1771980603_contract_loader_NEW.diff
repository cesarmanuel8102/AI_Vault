+# contract_loader.py (sandbox scaffold)
+from __future__ import annotations
+
+import json
+import hashlib
+from dataclasses import dataclass
+from datetime import datetime, timezone
+from pathlib import Path
+from typing import Any, Dict, Optional
+
+
+@dataclass
+class ContractLoadResult:
+    ok: bool
+    detail: str
+    data: Dict[str, Any]
+
+
+def _utc_iso() -> str:
+    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")
+
+
+def _sha256_bytes(b: bytes) -> str:
+    h = hashlib.sha256()
+    h.update(b)
+    return h.hexdigest()
+
+
+def load_contract_json(path: str) -> ContractLoadResult:
+    p = Path(path).resolve()
+    if not p.exists():
+        return ContractLoadResult(False, "NOT_FOUND", {"path": str(p)})
+
+    raw = p.read_bytes()
+    h = _sha256_bytes(raw)
+
+    try:
+        obj = json.loads(raw.decode("utf-8"))
+    except Exception as e:
+        return ContractLoadResult(False, "JSON_PARSE_ERROR", {"path": str(p), "error": str(e), "sha256": h})
+
+    # minimal schema validation
+    required_top = ["contract_id", "mission", "risk", "execution", "evaluation"]
+    missing = [k for k in required_top if k not in obj]
+    if missing:
+        return ContractLoadResult(False, "SCHEMA_MISSING_KEYS", {"missing": missing, "path": str(p), "sha256": h})
+
+    # normalize created_at
+    if obj.get("created_at_utc") in (None, "", "AUTO"):
+        obj["created_at_utc"] = _utc_iso()
+
+    # validate risk limits types
+    limits = (((obj.get("risk") or {}).get("limits")) or {})
+    for k in ["max_daily_loss_frac", "max_weekly_drawdown_frac", "max_total_exposure_frac"]:
+        v = limits.get(k, None)
+        if not isinstance(v, (int, float)):
+            return ContractLoadResult(False, "SCHEMA_BAD_TYPE", {"key": f"risk.limits.{k}", "value": v, "path": str(p)})
+
+    if not isinstance(limits.get("kill_switch", False), bool):
+        return ContractLoadResult(False, "SCHEMA_BAD_TYPE", {"key": "risk.limits.kill_switch", "value": limits.get("kill_switch"), "path": str(p)})
+
+    return ContractLoadResult(True, "OK", {"path": str(p), "sha256": h, "contract": obj})
+
+
+if __name__ == "__main__":
+    import sys
+    if len(sys.argv) < 2:
+        raise SystemExit("Usage: python contract_loader.py <contract_json_path>")
+    out = load_contract_json(sys.argv[1])
+    print(json.dumps({"ok": out.ok, "detail": out.detail, "data": out.data}, ensure_ascii=False, indent=2))
